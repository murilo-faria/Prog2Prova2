<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">
            jdbc:postgresql://localhost:5432/SisCom_comercial_prog2_Murilo
        </property>
        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">postgres</property>

        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>
        <property name="hibernate.highlight_sql">true</property>

        <property name="hibernate.hbm2ddl.auto">update</property>

        <mapping class="venda.siscom.model.Categoria"/>
        <mapping class="venda.siscom.model.Cliente"/>
        <mapping class="venda.siscom.model.Compra"/>
        <mapping class="venda.siscom.model.CompraProduto"/>
        <mapping class="venda.siscom.model.Financeiro"/>
        <mapping class="venda.siscom.model.FinanceiroParcela"/>
        <mapping class="venda.siscom.model.FormaPagamento"/>
        <mapping class="venda.siscom.model.Fornecedor"/>
        <mapping class="venda.siscom.model.FornecedorProduto"/>
        <mapping class="venda.siscom.model.Produto"/>
        <mapping class="venda.siscom.model.TipoConta"/>
        <mapping class="venda.siscom.model.Usuario"/>
        <mapping class="venda.siscom.model.Venda"/>
        <mapping class="venda.siscom.model.VendaProduto"/>

    </session-factory>
</hibernate-configuration>