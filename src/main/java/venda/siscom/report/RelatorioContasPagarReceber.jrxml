<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioContasPagarReceber"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <queryString>
        <![CDATA[
SELECT
    f.id AS financeiro_id,
    f.data_lancamento AS data_lancamento,
    CASE
        WHEN f.pagar_ou_receber = 0 THEN 'Pagar'
        ELSE 'Receber'
    END AS movimento,
    COALESCE(f.descricao, '') AS descricao,
    tc.descricao AS tipo_conta,
    fp.nome AS forma_pagamento,
    f.valor_total::double precision AS valor_total
FROM financeiro f
JOIN tipo_conta tc ON tc.id = f.tipo_conta_id
JOIN forma_pagamento fp ON fp.id = f.forma_pagamento_id
ORDER BY f.data_lancamento, f.pagar_ou_receber, f.id
        ]]>
    </queryString>

    <field name="financeiro_id" class="java.lang.Integer"/>
    <field name="data_lancamento" class="java.sql.Date"/>
    <field name="movimento" class="java.lang.String"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="tipo_conta" class="java.lang.String"/>
    <field name="forma_pagamento" class="java.lang.String"/>
    <field name="valor_total" class="java.lang.Double"/>

    <variable name="TOTAL_GERAL" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{valor_total}]]></variableExpression>
        <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
    </variable>

    <title>
        <band height="55">
            <staticText>
                <reportElement x="0" y="0" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[CONTAS A PAGAR / RECEBER]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="30" width="60" height="15"/>
                <text><![CDATA[Emitido:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="60" y="30" width="130" height="15"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="4" width="35" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="38" y="4" width="65" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Data]]></text>
            </staticText>
            <staticText>
                <reportElement x="106" y="4" width="60" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Mov.]]></text>
            </staticText>
            <staticText>
                <reportElement x="169" y="4" width="120" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Descricao]]></text>
            </staticText>
            <staticText>
                <reportElement x="292" y="4" width="95" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Tipo]]></text>
            </staticText>
            <staticText>
                <reportElement x="390" y="4" width="80" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Forma]]></text>
            </staticText>
            <staticText>
                <reportElement x="473" y="4" width="75" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Valor]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="21" width="555" height="1"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="2" width="35" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{financeiro_id}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="38" y="2" width="65" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{data_lancamento}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="106" y="2" width="60" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{movimento}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="169" y="2" width="120" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{descricao}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="292" y="2" width="95" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{tipo_conta}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="390" y="2" width="80" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{forma_pagamento}]]></textFieldExpression>
            </textField>
            <textField pattern="R$ #,##0.00">
                <reportElement x="473" y="2" width="75" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{valor_total}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="35">
            <line>
                <reportElement x="0" y="3" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="350" y="10" width="120" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total:]]></text>
            </staticText>
            <textField pattern="R$ #,##0.00">
                <reportElement x="473" y="10" width="75" height="18"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_GERAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
