<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioCompra"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <queryString>
        <![CDATA[
SELECT
    c.id AS compra_id,
    c.datacompra AS data_compra,
    f.nomefantasia AS fornecedor,
    f.cnpj AS cnpj,
    p.nome AS produto,
    cp.quantidade AS quantidade,
    cp.valorunitario::double precision AS valor_unitario,
    (cp.quantidade * cp.valorunitario)::double precision AS subtotal,
    c.valortotal::double precision AS valor_total
FROM compra c
JOIN fornecedor f ON f.id = c.fornecedor_id
JOIN compra_produto cp ON cp.compra_id = c.id
JOIN produto p ON p.id = cp.produto_id
ORDER BY c.datacompra, c.id, p.nome
        ]]>
    </queryString>

    <field name="compra_id" class="java.lang.Integer"/>
    <field name="data_compra" class="java.sql.Date"/>
    <field name="fornecedor" class="java.lang.String"/>
    <field name="cnpj" class="java.lang.String"/>
    <field name="produto" class="java.lang.String"/>
    <field name="quantidade" class="java.lang.Integer"/>
    <field name="valor_unitario" class="java.lang.Double"/>
    <field name="subtotal" class="java.lang.Double"/>
    <field name="valor_total" class="java.lang.Double"/>

    <variable name="TOTAL_GERAL" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
        <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
    </variable>

    <title>
        <band height="55">
            <staticText>
                <reportElement x="0" y="0" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[RELATORIO DE COMPRAS]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="30" width="60" height="15"/>
                <text><![CDATA[Emitido:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="60" y="30" width="130" height="15"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="4" width="35" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Compra]]></text>
            </staticText>
            <staticText>
                <reportElement x="38" y="4" width="65" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Data]]></text>
            </staticText>
            <staticText>
                <reportElement x="106" y="4" width="110" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Fornecedor]]></text>
            </staticText>
            <staticText>
                <reportElement x="219" y="4" width="120" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Produto]]></text>
            </staticText>
            <staticText>
                <reportElement x="342" y="4" width="35" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Qtd]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="4" width="80" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Unitario]]></text>
            </staticText>
            <staticText>
                <reportElement x="463" y="4" width="85" height="15"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Subtotal]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="21" width="555" height="1"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="2" width="35" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{compra_id}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="38" y="2" width="65" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{data_compra}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="106" y="2" width="110" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{fornecedor}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="219" y="2" width="120" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{produto}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="342" y="2" width="35" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{quantidade}]]></textFieldExpression>
            </textField>
            <textField pattern="R$ #,##0.00">
                <reportElement x="380" y="2" width="80" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{valor_unitario}]]></textFieldExpression>
            </textField>
            <textField pattern="R$ #,##0.00">
                <reportElement x="463" y="2" width="85" height="14"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{subtotal}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="35">
            <line>
                <reportElement x="0" y="3" width="555" height="1"/>
            </line>
            <staticText>
                <reportElement x="340" y="10" width="120" height="18"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total:]]></text>
            </staticText>
            <textField pattern="R$ #,##0.00">
                <reportElement x="463" y="10" width="85" height="18"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_GERAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
